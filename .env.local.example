# HorsePowr Web — public environment variables.
# Copy to `.env.local` and fill in. Both values are PUBLIC (anon key + RLS).
#
# HARD RULE: never add the Supabase service-role key to this project. The web
# app talks to Supabase with the anon key only; all access is governed by RLS.

# Your Supabase project URL, e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon (public) key. NOT the service-role key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: name of the deployed AI session-summary Edge Function.
# If unset or the function is not deployed, the app renders a deterministic,
# descriptive fallback summary instead. (See OVERNIGHT_WEB_REPORT.md §8.5.)
NEXT_PUBLIC_AI_SUMMARY_FUNCTION=session-summary
